# RideFlow backend environment template
# Copy to backend/.env for local non-Docker runs, or map these vars in AWS ECS.

DATABASE_URL=postgresql+asyncpg://rideflow:rideflow_dev@localhost:5432/rideflow
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
DEMO_MODE=true
# Comma-separated extra allowed frontend origins (no trailing slash).
# Localhost origins are always allowed by default in code.
CORS_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com
